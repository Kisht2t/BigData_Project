# ─── LLM ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Vector DB (Qdrant Cloud) ───────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=tech_news

# ─── AWS ────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/{your-account-id}/mars-agent-tasks

# DynamoDB
DYNAMODB_TABLE_NAME=mars-results
DYNAMODB_HISTORY_TABLE=mars-history

# S3
S3_BUCKET_NAME=mars-documents-{your-account-id}

# ─── App Config ─────────────────────────────────────────────────────────
# Orchestrator
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
WORKER_RESULT_TIMEOUT_SECONDS=30

# Worker
WORKER_POLL_WAIT_SECONDS=20
WORKER_MAX_RESULTS_PER_QUERY=5

# Ingestion
ARXIV_MAX_RESULTS=50
HN_MAX_RESULTS=100
GITHUB_MAX_REPOS=30
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ─── GitHub API (for ingestion — optional, increases rate limit) ─────────
GITHUB_TOKEN=ghp_...

# ─── Local dev only (overridden in AWS by Secrets Manager) ──────────────
# Set ENVIRONMENT=local to skip AWS Secrets Manager lookups
ENVIRONMENT=local
